{
  "$schema": "https://raw.githubusercontent.com/navidrome/navidrome/refs/heads/master/plugins/manifest-schema.json",
  "name": "Netease Music Plugin",
  "author": "sky8282",
  "version": "0.0.4",
  "description": "下载与写入本地：歌词、专辑封面、歌手头像、Qobuz 的 PDF (国内需科学网络)、专辑元数据文件、元数据写入记录",
  "website": "https://github.com/sky8282/Netease-navidrome-plugin",
  "permissions": {
    "users": {
      "reason": "开启写入本地权限，否则插件无法启动。"
    },
    "http": {
      "reason": "向 网易云 和 Qobuz 请求元数据与媒体文件",
      "requiredHosts": [
        "music.163.com",
        "interface3.music.163.com",
        "*.music.126.net",
        "www.qobuz.com",
        "static.qobuz.com"
      ]
    },
    "library": {
      "reason": "定位物理文件所在目录以直写 JPG、LRC 及 PDF 文件。",
      "filesystem": true
    },
    "subsonicapi": {
      "reason": "通过内部接口反查歌曲信息以实现绝对路径推导"
    },
    "kvstore": {
      "reason": "缓存网易云 API 的解析 ID 与图片链接以提升响应速度",
      "maxSize": "1048576"
    }
  },
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "enable_debug_log": { "type": "boolean", "title": "开启详细 Debug 日志", "default": true },
        "enable_write_lyrics": { "type": "boolean", "title": "写入本地歌词文件 (.lrc)", "default": true },
        "enable_write_pdf": { "type": "boolean", "title": "写入本地 PDF 文件 (.pdf)", "default": true },
        "enable_write_cover_image": { "type": "boolean", "title": "写入本地专辑封面文件 (cover.jpg)", "default": true },
        "enable_write_artist_image": { "type": "boolean", "title": "写入本地歌手头像文件 (artist.jpg)", "default": true },
        "enable_write_metadata": { "type": "boolean", "title": "增量写入本地音轨元数据（请慎用）", "default": true },
        "enable_lyrics": { "type": "boolean", "title": "全局歌词抓取 API (供某些客户端发出的请求)", "default": true },
        "navidrome_user": { "type": "string", "title": "请输入你的 navidrome 用户名，解决烦人的后台警报日志", "default": "admin" },
        "netease_cookie": { "type": "string", "title": "请输入网易云 MUSIC_U Cookie，获取相似艺人需要", "default": "" },
        "enable_qobuz_pdf": { "type": "boolean", "title": "下载 Qobuz PDF (需 🇫🇷 法国区 Qobuz Auth Tokens)", "default": true },
        "qobuz_auth_tokens": { "type": "string", "title": "请输入 🇫🇷 法国区 Qobuz Auth Tokens", "default": "dzDadAiP1ePUy3x1CIEbJ-VKcxQFHcB6f3eRlNSrOjPrwwxFiYckt0l5o7pevFMiAmGqbIroofkofYvovZlD0g" },
        "image_resolution": { "type": "string", "title": "可自定义网易云支持的图片分辨率", "default": "1200" },
        "cache_days": { "type": "integer", "title": "缓存天数 (默认 180 天)", "default": 180 }
      }
    },
    "uiSchema": {
      "type": "VerticalLayout",
      "elements": [
        { "type": "Control", "scope": "#/properties/enable_debug_log" },
        { "type": "Control", "scope": "#/properties/enable_write_lyrics" },
        { "type": "Control", "scope": "#/properties/enable_write_pdf" },
        { "type": "Control", "scope": "#/properties/enable_write_cover_image" },
        { "type": "Control", "scope": "#/properties/enable_write_artist_image" },
        { "type": "Control", "scope": "#/properties/enable_write_metadata" },
        { "type": "Control", "scope": "#/properties/enable_lyrics" },
        
        { "type": "Label", "text": "🔑" },
        
        { "type": "Label", "text": " " }, 
        { "type": "Label", "text": " " },
        
        { "type": "Control", "scope": "#/properties/navidrome_user" },
        { "type": "Control", "scope": "#/properties/netease_cookie" },
        { "type": "Control", "scope": "#/properties/enable_qobuz_pdf" },
        { "type": "Control", "scope": "#/properties/qobuz_auth_tokens" },
        { "type": "Control", "scope": "#/properties/image_resolution" },
        { "type": "Control", "scope": "#/properties/cache_days" }
      ]
    }
  }
}
